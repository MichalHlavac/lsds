# PostgreSQL
POSTGRES_DB=lsds
POSTGRES_USER=lsds
POSTGRES_PASSWORD=lsds
POSTGRES_HOST_PORT=5432

# API
API_PORT=3001
API_HOST_PORT=3001

# Web
WEB_PORT=3000
WEB_HOST_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Multi-tenant (on-prem single-tenant: set to your org slug)
TENANT_ID=default

# OIDC — API JWT verification (leave unset to disable)
# OIDC_ISSUER=https://your-idp.example.com
# OIDC_AUDIENCE=https://api.your-domain.com
# OIDC_JWKS_URI=https://your-idp.example.com/.well-known/jwks.json

# OIDC — Web OAuth client (leave unset to disable)
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
