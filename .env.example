# PostgreSQL
POSTGRES_DB=lsds
POSTGRES_USER=lsds
POSTGRES_PASSWORD=lsds
POSTGRES_HOST_PORT=5432

# API
API_PORT=3001
API_HOST_PORT=3001
# Comma-separated list of allowed CORS origins (default: http://localhost:3000)
# CORS_ORIGIN=http://localhost:3000

# Web
WEB_PORT=3000
WEB_HOST_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Multi-tenant (on-prem single-tenant: must be a valid UUID)
TENANT_ID=00000000-0000-0000-0000-000000000001

# Frontend tenant — must match TENANT_ID above.
# NEXT_PUBLIC_* vars are baked into the client bundle at Next.js build time;
# pass as a Docker build-arg (see docker-compose.yml build.args) or set before
# running `next build` locally.
NEXT_PUBLIC_TENANT_ID=00000000-0000-0000-0000-000000000001

# OIDC — API JWT verification (leave unset to disable)
# OIDC_ISSUER=https://your-idp.example.com
# OIDC_AUDIENCE=https://api.your-domain.com
# OIDC_JWKS_URI=https://your-idp.example.com/.well-known/jwks.json

# OIDC — Web OAuth client (leave unset to disable)
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
