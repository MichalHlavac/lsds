# Image version to pull from ghcr.io/michalhlavac/lsds
# Pin to a specific release tag (e.g. 1.1.0) for reproducible deployments.
LSDS_VERSION=latest

# PostgreSQL
POSTGRES_DB=lsds
POSTGRES_USER=lsds
# Required — set a strong password before running docker compose up
POSTGRES_PASSWORD=changeme
POSTGRES_HOST_PORT=5432

# API
API_PORT=3001
API_HOST_PORT=3001
# Comma-separated origins allowed by CORS (must match the web public URL)
CORS_ORIGIN=http://localhost:3000

# Web
WEB_PORT=3000
WEB_HOST_PORT=3000

# API URL as seen by the browser (must be publicly reachable from the client)
# NOTE: NEXT_PUBLIC_* vars are baked into the client bundle at Next.js build time.
# The pre-built image uses http://localhost:3001 as the default. Override requires
# a local rebuild (docker compose up --build).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Multi-tenant — must be a valid UUID; identifies this installation's tenant
TENANT_ID=00000000-0000-0000-0000-000000000001

# Frontend tenant — must match TENANT_ID above (also baked in at build time)
NEXT_PUBLIC_TENANT_ID=00000000-0000-0000-0000-000000000001

# OIDC — API JWT verification (leave unset to disable auth)
# OIDC_ISSUER=https://your-idp.example.com
# OIDC_AUDIENCE=https://api.your-domain.com
# OIDC_JWKS_URI=https://your-idp.example.com/.well-known/jwks.json

# OIDC — Web OAuth client (leave unset to disable)
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
